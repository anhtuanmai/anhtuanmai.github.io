# Development tasks — NOT used in GitHub Pages production builds.
#
# GitHub Pages builds the site itself from `docs/` using `_config.yml` only and
# never runs `rake`. This file lives inside `docs/` so it travels with the
# directory if `docs/` is deployed as a self-contained unit (e.g., to a dev
# server that runs `rake serve`).
#
# Usage (from this directory):
#   bundle exec rake          # default → serve
#   bundle exec rake serve    # dev server, reachable on LAN at port 4000
#   bundle exec rake build    # one-shot dev build with profile/trace
#
# Optional: create `_config.private.yml` (gitignored) for local-only secrets.
# It is auto-loaded if present; otherwise a warning is logged and the build
# continues with `_config.yml,_config.dev.yml`.

PRIVATE_CONFIG = '_config.private.yml'
PORT = 4000

def dev_config
  parts = ['_config.yml', '_config.dev.yml']
  if File.exist?(PRIVATE_CONFIG)
    parts << PRIVATE_CONFIG
    puts "[rake] using private overrides from #{PRIVATE_CONFIG}"
  else
    warn "[rake] WARNING: #{PRIVATE_CONFIG} not found — continuing without it. " \
         "Create it for local-only secrets (it's gitignored)."
  end
  parts.join(',')
end

task :default => %i[serve]

task :build do
  sh "jekyll build --profile --trace --config #{dev_config}"
end

task :serve do
  lan_ip = `hostname -I 2>/dev/null`.split.first
  puts "Local network: http://#{lan_ip}:#{PORT}" if lan_ip
  sh "jekyll serve --livereload --host 0.0.0.0 --port #{PORT} --config #{dev_config}"
end
